# ═══════════════════════════════════════════════════════
#  Stratalift — Environment Variables Template
#  Copy this file to the appropriate .env.local files.
# ═══════════════════════════════════════════════════════

# ── FRONTEND (frontend/.env.local) ────────────────────
VITE_API_URL=http://localhost:3001/api
VITE_MIDTRANS_CLIENT_KEY=SB-Mid-client-XXXXXXXX
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJxxxxxxx

# ── BACKEND (backend/.env.local) ─────────────────────
PORT=3001
NODE_ENV=development

# Supabase (⚠️ SECRET)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxxxx

# Midtrans (⚠️ SECRET)
MIDTRANS_IS_PRODUCTION=false
MIDTRANS_SERVER_KEY=SB-Mid-server-XXXXXXXX
MIDTRANS_CLIENT_KEY=SB-Mid-client-XXXXXXXX

# CORS
CORS_ORIGIN=http://localhost:5173
